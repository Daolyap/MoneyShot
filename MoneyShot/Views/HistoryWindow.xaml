<Window x:Class="MoneyShot.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Money Shot - Capture History"
        Height="640" Width="900"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
    <Window.Resources>
        <Style x:Key="ThumbBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Capture History" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Name="CountLabel" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="HistoryList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#1E293B" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="OpenFolderButton" Content="Open History Folder" Padding="14,6"
                        Background="#334155" Foreground="White" BorderBrush="#475569"
                        Click="OpenFolder_Click" Margin="0,0,8,0"/>
                <Button Content="Close" Padding="14,6" Background="#3B82F6" Foreground="White"
                        BorderBrush="#1D4ED8" Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
