<Window x:Class="MoneyShot.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Money Shot - Editor" Height="900" Width="1500"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">
    <Window.Resources>
        <!-- Glassmorphism Button Style -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#40FFFFFF" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#80FFFFFF" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.3" BlurRadius="8"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#60FFFFFF" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#80FFFFFF" Opacity="0.35"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Action Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E639C" Offset="0"/>
                        <GradientStop Color="#1177BB" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color Button Style -->
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="1" Opacity="0.5" BlurRadius="6"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Active tool button: brighter background + visible outline so the user can tell at a
             glance which tool is selected. Toggled by EditorWindow.UpdateActiveToolButton via Tag. -->
        <Style x:Key="ActiveToolButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1177BB" Offset="0"/>
                        <GradientStop Color="#FF0E5C8E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="12" BorderThickness="1">
        <Border.BorderBrush>
            <SolidColorBrush Color="White" Opacity="0.2"/>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.95">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="10" Opacity="0.5" BlurRadius="30"/>
        </Border.Effect>
        
        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Window Title Bar -->
            <Border Grid.Row="0" Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1" 
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="35">
                    <TextBlock Text="💰 Money Shot - Editor" 
                               Foreground="White" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               Margin="15,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                        <Button Content="🗕" Click="Minimize_Click" Style="{StaticResource GlassButton}" 
                                Width="40" Height="28" Padding="0" Margin="2,0"/>
                        <Button Content="🗖" Name="MaximizeRestoreButton" Click="MaximizeRestore_Click" Style="{StaticResource GlassButton}" 
                                Width="40" Height="28" Padding="0" Margin="2,0"/>
                        <Button Content="🗙" Click="Close_Click" Style="{StaticResource GlassButton}" 
                                Width="40" Height="28" Padding="0" Margin="2,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar with Glassmorphism -->
            <Border Grid.Row="1" Padding="10" Background="#15FFFFFF" BorderBrush="#25FFFFFF" BorderThickness="0,0,0,1">
                <Border.Effect>
                    <BlurEffect Radius="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Tool Selection -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Button Content="↖️ Cursor" Tag="Cursor" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Cursor Tool - Select and move elements"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="✂️ Crop" Tag="Crop" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Crop Tool"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="✏️ Rectangle (R)" Tag="Rectangle" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Rectangle Tool (Shortcut: R)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="⭕ Circle (C)" Tag="Circle" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Circle Tool (Shortcut: C)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="➡️ Arrow (A)" Tag="Arrow" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Arrow Tool (Shortcut: A)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="📏 Line (L)" Tag="Line" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Line Tool (Shortcut: L)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="✍️ Freehand (F)" Tag="Freehand" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Freehand Drawing Tool (Shortcut: F)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="🔢 Number (1)" Tag="Number" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Number Tool (Shortcut: 1)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="📝 Text (T)" Tag="Text" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Text Tool (Shortcut: T)"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Content="⬛ Pixelate (P)" Tag="Blur" Click="ToolButton_Click" Style="{StaticResource GlassButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Pixelate Tool (Shortcut: P) - Obscure sensitive info"/>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <!-- Color Selection -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                            <Button Background="Red" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Red"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Blue" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Blue"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Green" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Green"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Yellow" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Yellow"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Orange" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Orange"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Purple" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Purple"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="Black" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="Black"/>
                                </Button.ToolTip>
                            </Button>
                            <Button Background="White" Click="ColorButton_Click" Style="{StaticResource ColorButton}">
                                <Button.ToolTip>
                                    <ToolTip Content="White"/>
                                </Button.ToolTip>
                            </Button>
                            <!-- Custom colour picker: opens the system ColorDialog and sets the
                                 swatch background so the chosen colour persists for the session. -->
                            <Button Name="CustomColorButton" Click="CustomColorButton_Click"
                                    Style="{StaticResource ColorButton}" Background="#444444">
                                <Button.Content>
                                    <TextBlock Text="…" Foreground="White" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button.Content>
                                <Button.ToolTip>
                                    <ToolTip Content="Pick custom colour"/>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <!-- Stroke thickness slider — bound to _lineThickness in code-behind. -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="Stroke:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider Name="StrokeThicknessSlider"
                                    Width="100"
                                    Minimum="1" Maximum="10"
                                    Value="3"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="StrokeThicknessSlider_ValueChanged"/>
                            <TextBlock Name="StrokeThicknessLabel" Text="3" Foreground="White"
                                       VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="16"/>
                        </StackPanel>

                        <!-- Text Background -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="Text BG:" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Name="TextBackgroundComboBox"
                              Width="125"
                              Background="#3E3E42"
                              Foreground="Black"
                              BorderBrush="#555"
                              SelectionChanged="TextBackgroundComboBox_SelectionChanged">

                                <!-- Fix dropdown + item colors -->
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#3E3E42"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#555"/>

                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#555"/>
                                            </Trigger>

                                            <!-- Selected -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#007ACC"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>

                                <!-- Fix system highlight colors -->
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#3E3E42"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3E3E42"/>
                                </ComboBox.Resources>

                                <!-- Your items -->
                                <ComboBoxItem Content="Transparent" IsSelected="True"/>
                                <ComboBoxItem Content="White"/>
                                <ComboBoxItem Content="Black"/>
                                <ComboBoxItem Content="Yellow"/>
                                <ComboBoxItem Content="Red"/>
                                <ComboBoxItem Content="Blue"/>
                                <ComboBoxItem Content="Green"/>

                            </ComboBox>
                        </StackPanel>

                    </WrapPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="↶ Undo (Ctrl+Z)" Click="Undo_Click" Style="{StaticResource GlassButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Undo (Ctrl+Z)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="🔍+ Zoom" Click="ZoomIn_Click" Style="{StaticResource GlassButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Zoom In (Ctrl++)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="🔍- Zoom" Click="ZoomOut_Click" Style="{StaticResource GlassButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Zoom Out (Ctrl+-)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="🔍 Reset" Click="ZoomReset_Click" Style="{StaticResource GlassButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Reset Zoom (Ctrl+0)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="💾 Save (Ctrl+S)" Click="Save_Click" Style="{StaticResource PrimaryButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Save (Ctrl+S)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="📋 Copy (Ctrl+C)" Click="SaveToClipboard_Click" Style="{StaticResource PrimaryButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Copy to Clipboard (Ctrl+C)"/>
                            </Button.ToolTip>
                        </Button>
                        <Button Content="❓ Shortcuts (?)" Click="ShortcutsHelp_Click" Style="{StaticResource GlassButton}">
                            <Button.ToolTip>
                                <ToolTip Content="Show keyboard shortcuts (press ?)"/>
                            </Button.ToolTip>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Keyboard shortcut overlay. Hidden by default; toggled by `?` keypress or the
                 toolbar button. Click anywhere on it to dismiss. -->
            <Border Name="ShortcutsOverlay" Grid.Row="2" Visibility="Collapsed"
                    Background="#CC000000" Panel.ZIndex="100"
                    MouseLeftButtonDown="ShortcutsOverlay_MouseLeftButtonDown">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#1F2937" BorderBrush="#3B82F6" BorderThickness="2"
                        CornerRadius="10" Padding="24" MaxWidth="640">
                    <StackPanel>
                        <TextBlock Text="Keyboard Shortcuts" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Tools" Foreground="#93C5FD" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="R — Rectangle"     Foreground="White" Margin="0,2"/>
                                <TextBlock Text="C — Circle"        Foreground="White" Margin="0,2"/>
                                <TextBlock Text="A — Arrow"         Foreground="White" Margin="0,2"/>
                                <TextBlock Text="L — Line"          Foreground="White" Margin="0,2"/>
                                <TextBlock Text="F — Freehand"      Foreground="White" Margin="0,2"/>
                                <TextBlock Text="T — Text"          Foreground="White" Margin="0,2"/>
                                <TextBlock Text="P — Pixelate"      Foreground="White" Margin="0,2"/>
                                <TextBlock Text="1 — Number label"  Foreground="White" Margin="0,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Editor" Foreground="#93C5FD" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="Ctrl+Z — Undo"           Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Ctrl+C — Copy to clipboard" Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Ctrl+S — Save"           Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Ctrl++ / Ctrl+- — Zoom"   Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Ctrl+0 — Reset zoom"      Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Delete — Remove selected" Foreground="White" Margin="0,2"/>
                                <TextBlock Text="Esc — Close editor"       Foreground="White" Margin="0,2"/>
                                <TextBlock Text="? — Toggle this overlay"  Foreground="White" Margin="0,2"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Click anywhere or press any key to dismiss"
                                   Foreground="#9CA3AF" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Main Canvas Area -->
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.3">
                        <GradientStop Color="#0a0a0a" Offset="0"/>
                        <GradientStop Color="#1a1a1a" Offset="1"/>
                    </LinearGradientBrush>
                </ScrollViewer.Background>
                <Grid Name="ImageCanvas" HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" CenterX="0" CenterY="0"/>
                    </Grid.RenderTransform>
                    <Image Name="ImageDisplay" />
                    <Canvas Name="DrawingCanvas" 
                            MouseDown="Canvas_MouseDown"
                            MouseMove="Canvas_MouseMove"
                            MouseUp="Canvas_MouseUp"
                            Background="Transparent"
                            SnapsToDevicePixels="True"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
